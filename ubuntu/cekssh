#!/bin/bash

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
NC='\033[0m'

clear

# Simple clean header
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${WHITE}           🔐 USER CONNECTION MONITOR${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo

# Log file paths
AUTH_LOG="/var/log/auth.log"
SYS_LOG="/var/log/syslog"

# Quick checks
[ ! -e "$AUTH_LOG" ] && echo -e "${RED}❌ $AUTH_LOG not found!${NC}" && exit 1
[ ! -e "$SYS_LOG" ] && echo -e "${RED}❌ $SYS_LOG not found!${NC}" && exit 1

# Initialize counters
dropbear_count=0
ssh_count=0
ovpn_tcp_count=0
ovpn_udp_count=0

echo -e "${YELLOW}🔍 Scanning connections...${NC}"
echo

# Simple table header
printf "${CYAN}%-10s %-8s %-12s %-18s${NC}\n" "SERVICE" "PID" "USER" "IP:PORT"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Function to show connection
show_conn() {
    printf "%-10s %-8s ${GREEN}%-12s${NC} %-18s\n" "$1" "$2" "$3" "$4"
}

# DROPBEAR
dropbear_pids=($(ps aux | grep -i dropbear | grep -v grep | awk '{print $2}' 2>/dev/null))
if [ ${#dropbear_pids[@]} -gt 0 ]; then
    grep -i dropbear "$SYS_LOG" | grep -i "Password auth succeeded" > /tmp/login-db.txt 2>/dev/null
    
    for PID in "${dropbear_pids[@]}"; do
        if [[ "$PID" =~ ^[0-9]+$ ]]; then
            grep "dropbear\[$PID\]" /tmp/login-db.txt > /tmp/login-db-pid.txt 2>/dev/null
            if [ -s /tmp/login-db-pid.txt ]; then
                USER=$(sed -n "s/.*Password auth succeeded for '\([^']*\)' from.*/\1/p" /tmp/login-db-pid.txt | head -1)
                IP_PORT=$(sed -n "s/.*from \([^ ]*\).*/\1/p" /tmp/login-db-pid.txt | head -1)
                if [ -n "$USER" ] && [ -n "$IP_PORT" ]; then
                    show_conn "DROPBEAR" "$PID" "$USER" "$IP_PORT"
                    dropbear_count=$((dropbear_count + 1))
                fi
            fi
        fi
    done
fi

# SSH
active_sessions=($(ps aux | grep '[s]shd:' | awk '{print $2}' 2>/dev/null))
if [ ${#active_sessions[@]} -gt 0 ]; then
    grep -i sshd "$AUTH_LOG" | grep -i "Accepted password for" > /tmp/login-ssh.txt 2>/dev/null
    
    for PID in "${active_sessions[@]}"; do
        if [[ "$PID" =~ ^[0-9]+$ ]]; then
            grep "sshd\[$PID\]" /tmp/login-ssh.txt > /tmp/login-ssh-pid.txt 2>/dev/null
            if [ -s /tmp/login-ssh-pid.txt ]; then
                USER=$(sed -n "s/.*Accepted password for \([^ ]*\) from.*/\1/p" /tmp/login-ssh-pid.txt | head -1)
                IP_PORT=$(sed -n "s/.*from \([^ ]*\) port \([^ ]*\).*/\1:\2/p" /tmp/login-ssh-pid.txt | head -1)
                if [ -n "$USER" ] && [ -n "$IP_PORT" ]; then
                    show_conn "SSH" "$PID" "$USER" "$IP_PORT"
                    ssh_count=$((ssh_count + 1))
                fi
            fi
        fi
    done
fi

# OpenVPN TCP
if [ -f "/etc/openvpn/server/openvpn-tcp.log" ]; then
    grep -w "^CLIENT_LIST" /etc/openvpn/server/openvpn-tcp.log 2>/dev/null | while IFS=',' read -r _ user ip _ _ _ _ connected _; do
        if [ -n "$user" ] && [ "$user" != "HEADER" ] && [ "$user" != "CLIENT_LIST" ]; then
            show_conn "OVPN-TCP" "-" "$user" "$ip"
            ovpn_tcp_count=$((ovpn_tcp_count + 1))
        fi
    done
fi

# OpenVPN UDP  
if [ -f "/etc/openvpn/server/openvpn-udp.log" ]; then
    grep -w "^CLIENT_LIST" /etc/openvpn/server/openvpn-udp.log 2>/dev/null | while IFS=',' read -r _ user ip _ _ _ _ connected _; do
        if [ -n "$user" ] && [ "$user" != "HEADER" ] && [ "$user" != "CLIENT_LIST" ]; then
            show_conn "OVPN-UDP" "-" "$user" "$ip"
            ovpn_udp_count=$((ovpn_udp_count + 1))
        fi
    done
fi

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo

# Summary
echo -e "${WHITE}📊 CONNECTION SUMMARY${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "🔐 Dropbear SSH: ${GREEN}$dropbear_count${NC} connections"
echo -e "🚪 OpenSSH:      ${GREEN}$ssh_count${NC} connections"
echo -e "🔒 OpenVPN TCP:  ${GREEN}$ovpn_tcp_count${NC} connections"  
echo -e "🔓 OpenVPN UDP:  ${GREEN}$ovpn_udp_count${NC} connections"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

total=$((dropbear_count + ssh_count + ovpn_tcp_count + ovpn_udp_count))
echo -e "📈 ${YELLOW}Total Active: $total connections${NC}"
echo -e "⏰ Scanned at: ${WHITE}$(date +'%H:%M:%S')${NC}"

# Cleanup
rm -f /tmp/login-*.txt 2>/dev/null

echo
if [ "$total" -gt 0 ]; then
    echo -e "${GREEN}✅ Found $total active connections${NC}"
else
    echo -e "${YELLOW}ℹ️  No active connections found${NC}"
fi