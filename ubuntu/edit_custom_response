#!/bin/bash

# COLOR DEFINITIONS
clear
y='\033[1;33m' #yellow
BGX="\033[42m"
CYAN="\033[96m"
z="\033[96m"
RED='\033[0;31m'
NC='\033[0m'
gray="\e[1;30m"
Blue="\033[0;34m"
orange_bold='\033[1;38;5;214m'
green='\033[0;32m'
grenbo="\e[92;1m"
purple="\033[1;95m"
bold_white="\033[1;97m"
YELL='\033[0;33m'
yellow='\033[1;33m'

# NEW 2025 COLORS
neon_green='\033[38;5;46m'
cyber_blue='\033[38;5;51m'
matrix_green='\033[38;5;40m'
electric_purple='\033[38;5;129m'
gold='\033[38;5;220m'
silver='\033[38;5;250m'

# Enhanced symbols
FIRE="[*]"
SKULL="[X]"
