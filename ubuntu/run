# // Exporting IP Address
export IP=$( curl -s https://ipinfo.io/ip/ )

# FIXED: More reliable service status checking functions
check_service_status() {
    local service_name="$1"
    local init_script="$2"
    
    # Try systemctl first (more reliable)
    if systemctl is-active --quiet "$service_name" 2>/dev/null; then
        echo "running"
        return
    fi
    
    # Fallback to init.d script if provided
    if [[ -n "$init_script" ]] && [[ -x "/etc/init.d/$init_script" ]]; then
        local status=$(/etc/init.d/$init_script status 2>/dev/null | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
        echo "$status"
    else
        echo "inactive"
    fi
}

# Enhanced WebSocket service check with multiple methods
check_ws_service() {
    # Method 1: Check if systemctl reports it as active
    if systemctl is-active --quiet ws 2>/dev/null; then
        echo "running"
        return
    fi
    
    # Method 2: Check if the process is actually running and listening
    if pgrep -f "/usr/bin/ws" >/dev/null && netstat -tlnp 2>/dev/null | grep -q ":10015.*LISTEN"; then
        echo "running"
        return
    fi
    
    # Method 3: Try to connect to the service (functional test)
    if timeout 2 bash -c "</dev/tcp/localhost/10015" 2>/dev/null; then
        echo "running"
        return
    fi
    
    echo "inactive"
}

# // SSH
